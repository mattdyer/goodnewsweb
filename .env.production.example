# Production Environment Variables Template
# Copy this file to .env.production and fill in actual values

# NextAuth Configuration
NEXTAUTH_URL=https://goodnews.example.com
NEXTAUTH_SECRET=your-secure-random-secret-min-32-chars

# API Configuration
NEXT_PUBLIC_API_URL=https://api.goodnews.example.com
PAPERCLIP_URL=https://api.goodnews.example.com

# Stripe Configuration (Production)
STRIPE_SECRET_KEY=sk_live_your_stripe_production_key
STRIPE_WEBHOOK_SECRET=whsec_your_production_webhook_secret
STRIPE_MONTHLY_PRICE_ID=price_your_production_monthly_id
STRIPE_YEARLY_PRICE_ID=price_your_production_yearly_id

# Google Analytics
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXXXX
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense (Production)
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADSENSE_SLOT=XXXXXXXXXX

# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/goodnews
